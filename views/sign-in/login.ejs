<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Letterboxd — Sign In</title>
    <link
      rel="shortcut icon"
      sizes="196x196"
      href="/public/img/favicon.ico"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Martel+Sans:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background: #141414;
        font-family: "Martel Sans", sans-serif;
        color: #ffffff;
        min-height: 100vh;
      }

      /* ── Navbar ── */
      .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 40px;
        background: rgba(0, 0, 0, 0.85);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .logo {
        font-size: 28px;
        font-weight: 900;
        color: #E50914;
        text-decoration: none;
        letter-spacing: 1px;
      }
      .nav-link {
        color: #808080;
        text-decoration: none;
        font-size: 15px;
        font-weight: 600;
        transition: color 0.2s;
      }
      .nav-link:hover {
        color: #ffffff;
      }

      /* ── Main container ── */
      .auth-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 80px);
        padding: 40px 20px;
      }
      .auth-card {
        background: rgba(0, 0, 0, 0.75);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 60px 68px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
      }
      .auth-card h1 {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 28px;
        color: #ffffff;
      }

      /* ── Error message ── */
      .error-msg {
        background: rgba(229, 9, 20, 0.15);
        border: 1px solid #E50914;
        color: #E50914;
        padding: 12px 16px;
        border-radius: 6px;
        font-size: 14px;
        margin-bottom: 20px;
      }

      /* ── Form fields ── */
      .form-group {
        margin-bottom: 20px;
      }
      .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #808080;
        margin-bottom: 8px;
      }
      .form-group input {
        width: 100%;
        padding: 14px 16px;
        font-size: 16px;
        border-radius: 6px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: #333333;
        color: #ffffff;
        outline: none;
        transition: border-color 0.2s;
        font-family: "Martel Sans", sans-serif;
      }
      .form-group input:focus {
        border-color: #E50914;
      }
      .form-group input::placeholder {
        color: #808080;
      }

      /* ── Submit button ── */
      .btn-submit {
        width: 100%;
        padding: 14px;
        background: #E50914;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s;
        font-family: "Martel Sans", sans-serif;
      }
      .btn-submit:hover {
        background: #B20710;
      }

      /* ── Footer link ── */
      .auth-footer {
        text-align: center;
        margin-top: 24px;
        font-size: 14px;
        color: #808080;
      }
      .auth-footer a {
        color: #E50914;
        text-decoration: none;
        font-weight: 600;
      }
      .auth-footer a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <!-- Navbar -->
    <nav class="nav-bar">
      <a href="/" class="logo">LETTERBOXD</a>
      <a href="/signup" class="nav-link">Create Account</a>
    </nav>

    <!-- Login Form -->
    <div class="auth-container">
      <div class="auth-card">
        <h1>Sign In</h1>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <form action="/login" method="post">
          <div class="form-group">
            <label for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter your password"
              required
            />
          </div>

          <button type="submit" class="btn-submit">Sign In</button>
        </form>

        <p class="auth-footer">
          New to Letterboxd? <a href="/signup">Create an account</a>
        </p>
      </div>
    </div>
  </body>
</html>
